</owl:Class>

<owl:Class rdf:about="#SyntheticToxin">
  <rdfs:subClassOf rdf:resource="#Toxin"/>
</owl:Class>

<owl:Class rdf:about="#ChemicalConcept"/>

<owl:Class rdf:about="#CopyNumberVariant">
  <rdfs:subClassOf rdf:resource="#GeneticEntity"/>
</owl:Class>

<owl:Class rdf:about="#GeneticEntity">
  <rdfs:subClassOf rdf:resource="#HumanConcept"/>
</owl:Class>

