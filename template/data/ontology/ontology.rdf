<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#AnimalToxin"/>
    <rdf:Description rdf:about="#FungalToxin"/>
    <rdf:Description rdf:about="#MicrobialToxin"/>
    <rdf:Description rdf:about="#PlantToxin"/>
