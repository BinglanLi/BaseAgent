  <rdfs:subClassOf rdf:resource="#Species"/>
  <owl:disjointWith rdf:resource="#NonHumanSpecies"/>
</owl:Class>

<owl:Class rdf:about="#NonHumanSpecies">
  <rdfs:subClassOf rdf:resource="#Species"/>
</owl:Class>

<owl:Class rdf:about="#HumanMolecule">
  <rdfs:subClassOf rdf:resource="#BodyPart"/>
</owl:Class>

<owl:Class rdf:about="#HumanNucleicAcid">
  <rdfs:subClassOf rdf:resource="#HumanMolecule"/>
</owl:Class>

<owl:Class rdf:about="#HumanSmallMolecule">
  <rdfs:subClassOf rdf:resource="#HumanMolecule"/>
</owl:Class>

<owl:Class rdf:about="#LossOfFunctionMutation">
  <rdfs:subClassOf rdf:resource="#Mutation"/>
</owl:Class>

<owl:Class rdf:about="#MetabolicPathway">
  <rdfs:subClassOf rdf:resource="#Pathway"/>
  <owl:disjointWith rdf:resource="#SignalTransductionPathway"/>
</owl:Class>

<owl:Class rdf:about="#SignalTransductionPathway">
  <rdfs:subClassOf rdf:resource="#Pathway"/>
</owl:Class>

<owl:Class rdf:about="#MicrobialToxin">
  <rdfs:subClassOf rdf:resource="#Biotoxin"/>
</owl:Class>

<owl:Class rdf:about="#PharmaceuticalDrug">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Drug"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#drugTreatsDisease"/>
          <owl:onClass rdf:resource="#Disease"/>
          <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#Drug"/>
  <rdfs:comment xml:lang="en">A drug with an intended beneficial effect, intended to 'treat, cure, prevent, or diagnose a disease or promote well-being.'</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#PlantToxin">
  <rdfs:subClassOf rdf:resource="#Biotoxin"/>
</owl:Class>

<owl:Class rdf:about="#SingleNucleotidePolymorphism">
  <rdfs:subClassOf rdf:resource="#GeneticEntity"/>
</owl:Class>

<owl:Class rdf:about="#TherapeuticEffect">
  <rdfs:subClassOf rdf:resource="#ChemicalEffect"/>
</owl:Class>

<owl:Class rdf:about="#TissueType">
  <rdfs:subClassOf rdf:resource="#BodyPart"/>
</owl:Class>

<owl:Class rdf:about="#VenomComponent">
  <rdfs:subClassOf rdf:resource="#AnimalToxin"/>
</owl:Class>

<owl:Class rdf:about="#Variant">
