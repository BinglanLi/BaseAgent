  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#xrefAOPWikiAOPID"/>
    <rdf:Description rdf:about="#xrefAOPWikiKEID"/>
    <rdf:Description rdf:about="#xrefAOPWikiKERID"/>
    <rdf:Description rdf:about="#xrefAOPWikiStressorID"/>
  </owl:members>
</owl:AllDisjointProperties>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#HumanNucleicAcid"/>
    <rdf:Description rdf:about="#HumanProtein"/>
    <rdf:Description rdf:about="#HumanSmallMolecule"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#Database"/>
    <rdf:Description rdf:about="#Finding"/>
