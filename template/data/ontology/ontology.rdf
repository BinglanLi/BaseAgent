    <rdf:Description rdf:about="#Study"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#CellType"/>
    <rdf:Description rdf:about="#HumanMolecule"/>
    <rdf:Description rdf:about="#Organ"/>
    <rdf:Description rdf:about="#OrganSystem"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#BodyPart"/>
    <rdf:Description rdf:about="#Disease"/>
    <rdf:Description rdf:about="#ExposureEvent"/>
    <rdf:Description rdf:about="#GeneticEntity"/>
    <rdf:Description rdf:about="#Human"/>
    <rdf:Description rdf:about="#Pathway"/>
    <rdf:Description rdf:about="#RiskFactor"/>
  </owl:members>
